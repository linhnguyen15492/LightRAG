<node id="MongoDB Atlas Vector Search">
  <data key="d0">MongoDB Atlas Vector Search</data>
  <data key="d1">data</data>
  <data key="d2">MongoDB Atlas Vector Search combines traditional document storage with vector search capabilities for unified data management.</data>
