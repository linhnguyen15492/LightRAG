  <data key="d5">1775461487</data>
  <data key="d6"></data>
</node>
<node id="Milvus">
  <data key="d0">Milvus</data>
  <data key="d1">data</data>
  <data key="d2">Milvus is a high-performance vector database that efficiently handles large-scale vector collections and supports vector search at scale.</data>
  <data key="d3">chunk-a7534773ede26ba695c6f58ad56a167d</data>
  <data key="d4">lightrag/evaluation/sample_documents/04_supported_databases.md</data>
  <data key="d5">1775461487</data>
  <data key="d6"></data>
</node>
<node id="Qdrant">
  <data key="d0">Qdrant</data>
  <data key="d1">data</data>
  <data key="d2">Qdrant is a vector database that offers fast similarity search and filtering capabilities, providing production-ready vector search infrastructure.</data>
