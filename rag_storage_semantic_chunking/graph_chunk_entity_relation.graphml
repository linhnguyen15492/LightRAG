</node>
<node id="Faithfulness Metric">
  <data key="d0">Faithfulness Metric</data>
  <data key="d1">metric</data>
  <data key="d2">The Faithfulness Metric measures whether answers are factually grounded in retrieved context and detects hallucinations in LLM responses.</data>
  <data key="d3">chunk-0a6a2a571099c70c7e20dbd90da662e2</data>
  <data key="d4">lightrag/evaluation/sample_documents/05_evaluation_and_deployment.md</data>
  <data key="d5">1775461507</data>
  <data key="d6"></data>
</node>
<node id="Answer Relevance Metric">
  <data key="d0">Answer Relevance Metric</data>
  <data key="d1">metric</data>
  <data key="d2">The Answer Relevance Metric evaluates how well answers address user questions, measuring the quality and appropriateness of responses.</data>
  <data key="d3">chunk-0a6a2a571099c70c7e20dbd90da662e2</data>
  <data key="d4">lightrag/evaluation/sample_documents/05_evaluation_and_deployment.md</data>
  <data key="d5">1775461508</data>
  <data key="d6"></data>
</node>
<node id="Context Recall Metric">
  <data key="d0">Context Recall Metric</data>
  <data key="d1">metric</data>
  <data key="d2">The Context Recall Metric assesses the completeness of information retrieval from documents, indicating the effectiveness of the retrieval system.</data>
  <data key="d3">chunk-0a6a2a571099c70c7e20dbd90da662e2</data>
  <data key="d4">lightrag/evaluation/sample_documents/05_evaluation_and_deployment.md</data>
  <data key="d5">1775461508</data>
  <data key="d6"></data>
</node>
<node id="Context Precision Metric">
  <data key="d0">Context Precision Metric</data>
